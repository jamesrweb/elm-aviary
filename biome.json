{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "master"
  },
  "files": {
    "includes": ["**", "!review/suppressed"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  }
}
